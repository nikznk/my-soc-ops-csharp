@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="square-label">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="square-check" aria-hidden="true">+</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var classes = "bingo-square";

        var stateClass = Square.IsMarked
            ? IsWinning
                ? "square-winning"
                : "square-marked"
            : "square-default";

        classes = $"{classes} {stateClass}";

        if (Square.IsFreeSpace)
        {
            classes = $"{classes} square-free";
        }

        return classes;
    }
}
