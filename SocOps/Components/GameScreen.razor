@using SocOps.Models

<section class="game-screen">
    <header class="game-header">
        <button
            @onclick="OnReset"
            class="game-back-button">
            Abort Mission
        </button>

        <h1 class="game-title">Soc Ops</h1>

        <span class="game-chip">Live Round</span>
    </header>

    <p class="game-instructions">Tap a square after you find someone who matches the prompt.</p>

    @if (HasBingo)
    {
        <div class="bingo-banner" role="status" aria-live="polite">
            Bingo achieved. Signal locked.
        </div>
    }

    <div class="game-board-wrap">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</section>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
