<div class="modal-scrim" role="dialog" aria-modal="true" aria-label="Bingo achieved">
    <div class="bingo-modal">
        <p class="modal-kicker">Transmission Success</p>
        <h2 class="modal-title">Bingo</h2>
        <p class="modal-copy">Your team locked a full line. Keep scouting and stack another one.</p>

        <button
            @onclick="OnDismiss"
            class="modal-button">
            Continue Sweep
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
