<section class="start-screen">
    <div class="start-grid">
        <div class="start-hero">
            <p class="start-kicker">Icebreaker Protocol</p>
            <h1 class="start-title">Soc Ops</h1>
            <p class="start-subtitle">Social Bingo</p>
            <p class="start-copy">Scan the room, collect human signals, and complete your line before anyone else does.</p>
        </div>

        <div class="rules-panel">
            <h2 class="rules-title">Mission Rules</h2>
            <ul class="rules-list">
                <li>Find people who match each square prompt</li>
                <li>Tag a square when you find a match</li>
                <li>Complete any 5 in a row to trigger Bingo</li>
            </ul>

            <button
                @onclick="OnStart"
                class="start-button">
                Launch Round
            </button>
        </div>
    </div>
</section>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
