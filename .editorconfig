# EditorConfig for C# projects
# https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
# Unused variables and parameters
dotnet_code_quality_unused_parameters = all:warning
dotnet_diagnostic.CS0168.severity = warning   # Variable is declared but never used
dotnet_diagnostic.CS0219.severity = warning   # Variable is assigned but its value is never used
dotnet_diagnostic.IDE0059.severity = warning  # Unnecessary assignment
dotnet_diagnostic.IDE0060.severity = warning  # Remove unused parameter

# Async/await usage
dotnet_diagnostic.CS1998.severity = warning   # Async method lacks await
dotnet_diagnostic.CS4014.severity = warning   # Call not awaited

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
